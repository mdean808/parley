{
	"name": "simple-implementation",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"protocols",
		"benchmark",
		"apps/*"
	],
	"scripts": {
		"chat": "bun run apps/cli-chat/src/index.ts",
		"bench": "bun run benchmark/src/cli.ts",
		"web": "bun run --cwd apps/web-chat dev",
		"lint": "bunx biome check .",
		"format": "bunx biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@types/bun": "latest"
	}
}
